# Copy to .env and fill in. Never commit the real .env.

# --- App ---
ENVIRONMENT=development
FRONTEND_BASE_URL=http://localhost:5173

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL=postgresql+psycopg://streamgt:streamgt@postgres:5432/streamgt

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- S3 object storage ---
S3_BUCKET=streamgt-data
S3_REGION=eu-central-1
# For AWS leave S3_ENDPOINT_URL empty; set it for MinIO/localstack (e.g. http://minio:9000)
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PRESIGN_EXPIRE_SECONDS=3600

# --- Email (SMTP / SES) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM=no-reply@streamgt.local

# --- Pipeline execution (worker) ---
PIPELINE_DIR=/app/pipeline
NEXTFLOW_PROFILE=docker
JOB_SCRATCH_ROOT=/scratch
