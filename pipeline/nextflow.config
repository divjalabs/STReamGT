profiles {

  docker {
    docker.enabled = true
    process.container = 'stream:latest'
  }

  singularity_Ribica {
    singularity.enabled = true
    singularity.autoMounts = true
    process.container = '/mnt/disk2/ekoz/ngs/obitools4_py.sif'
  }

  // Cloud execution: each pipeline process runs as its own AWS Batch job (Fargate/EC2 Spot).
  // Values are env-configurable so the image/queue/work-dir aren't hard-coded to one account.
  // Requires the AWS CLI inside the container (see pipeline/Dockerfile) at aws.batch.cliPath.
  awsbatch {
    process.executor  = 'awsbatch'
    process.queue     = System.getenv('NXF_BATCH_QUEUE')   ?: 'streamgt-queue'
    process.container = System.getenv('OBITOOLS_IMAGE')    ?: 'stream:latest'
    aws.region        = System.getenv('AWS_REGION')        ?: 'eu-central-1'
    aws.batch.cliPath = '/usr/local/bin/aws'
    workDir           = System.getenv('NXF_WORK')          ?: 's3://streamgt-data/work'
  }

}